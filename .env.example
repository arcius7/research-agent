# ─────────────────────────────────────────────────────────────────────────────
# Research Agent — environment configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the keys you want to use.
# Any key left blank or commented out is ignored — the agent falls back to
# local Ollama for that capability.
#
#   cp .env.example .env
#   nano .env          # paste your key(s)
#   python server.py   # cloud models now appear in the model picker
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ───────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Google Gemini ────────────────────────────────────────────────────────────
# GEMINI_API_KEY=...

# ── Groq (fast open-source models) ──────────────────────────────────────────
# GROQ_API_KEY=gsk_...

# ── Together AI ──────────────────────────────────────────────────────────────
# TOGETHER_API_KEY=...

# ── Local Ollama (always available, no key needed) ───────────────────────────
# LLM_MODEL=gemma4:e4b           # default Ollama model for answers
# EMBED_MODEL=nomic-embed-text   # default Ollama embedding model
# OLLAMA_BASE=http://localhost:11434

# CLOUD_NUM_PRED=2048            # max answer tokens for cloud models

# ── Server ───────────────────────────────────────────────────────────────────
# PORT=8765
# HOST=127.0.0.1                 # set 0.0.0.0 to expose on your LAN (unsafe)
# MAX_UPLOAD_MB=100
